#!/usr/bin/bash

args=""
save_dir="./benchmon_savedir_${SLURM_JOB_ID}${OAR_JOB_ID}"
while [[ $# -gt 0 ]]; do
    case $1 in
        "-l" | "--level")
            level=$2
            shift 2
            ;;
        "-d" | "--save-dir")
            save_dir=$2
            shift 2
            ;;
        "--report-template")
            report_template=$2
            shift 2
            ;;
        *)
            args="$args $1"
            shift 1
            ;;
    esac
done

traces_repo=$save_dir #/benchmon_traces_$(hostname)

# ------------------------------
# Postprocessing: Benchmon Visualisation
# ------------------------------

benchmon_visu=$(dirname $0)/benchmon-visu
annotations_args=""
events_file="$traces_repo/events.csv"
if [[ -f "$events_file" ]]; then
    annotations_args="--annotate-with-log $events_file"
fi
if [[ $level == 0 ]]; then
    $benchmon_visu --recursive --cpu --mem --net --disk --fig-fmt png,svg --fig-dpi medium --fig-name benchmon_figure_overview $traces_repo
    $benchmon_visu --recursive --cpu --cpu-all --cpu-freq --mem --net --net-all --net-data --disk --disk-data --disk-iops --fig-fmt png,svg --fig-dpi medium --fig-name benchmon_figure_detailed $traces_repo
    # Only call benchmon-visu with annotation if annotation arguments are set
    # (i.e., events.csv exists), to avoid generating duplicate non-annotated plots
    if [[ -n "$annotations_args" ]]; then
        $benchmon_visu --recursive --cpu --mem --net --disk --fig-fmt png,svg --fig-dpi medium $annotations_args --fig-name benchmon_figure_overview_annotated $traces_repo
        $benchmon_visu --recursive --cpu --cpu-all --cpu-freq --mem --net --net-all --net-data --disk --disk-data --disk-iops --fig-fmt png,svg --fig-dpi medium $annotations_args --fig-name benchmon_figure_detailed_annotated $traces_repo
    fi
elif [[ $level == 1 ]]; then
    $benchmon_visu --recursive --cpu --mem --net --disk --inline-call --fig-fmt png,svg --fig-dpi medium --fig-name benchmon_figure_overview $traces_repo
    $benchmon_visu --recursive --cpu --cpu-all --cpu-freq --mem --net --net-all --net-data --disk --disk-data --disk-iops --inline-call --fig-fmt png,svg --fig-dpi medium --fig-name benchmon_figure_detailed $traces_repo # --pow
    if [[ -n "$annotations_args" ]]; then
        $benchmon_visu --recursive --cpu --mem --net --disk --inline-call --fig-fmt png,svg --fig-dpi medium $annotations_args --fig-name benchmon_figure_overview_annotated $traces_repo
        $benchmon_visu --recursive --cpu --cpu-all --cpu-freq --mem --net --net-all --net-data --disk --disk-data --disk-iops --inline-call --fig-fmt png,svg --fig-dpi medium $annotations_args --fig-name benchmon_figure_detailed_annotated $traces_repo # --pow
    fi
elif [[ $level == 2 ]]; then
    $benchmon_visu --recursive --cpu --mem --net --disk --inline-call --call --call-depth 4 --fig-fmt png,svg --fig-dpi medium --fig-name benchmon_figure_overview $traces_repo
    $benchmon_visu --recursive --cpu --cpu-all --cpu-freq --mem --net --net-all --net-data --disk --disk-data --disk-iops --inline-call --call --call-depth 4 --fig-fmt png,svg --fig-dpi medium --fig-name benchmon_figure_detailed $traces_repo # --pow
    if [[ -n "$annotations_args" ]]; then
        $benchmon_visu --recursive --cpu --mem --net --disk --inline-call --call --call-depth 4 --fig-fmt png,svg --fig-dpi medium $annotations_args --fig-name benchmon_figure_overview_annotated $traces_repo
        $benchmon_visu --recursive --cpu --cpu-all --cpu-freq --mem --net --net-all --net-data --disk --disk-data --disk-iops --inline-call --call --call-depth 4 --fig-fmt png,svg --fig-dpi medium $annotations_args --fig-name benchmon_figure_detailed_annotated $traces_repo # --pow
    fi
fi

# ------------------------------
# Postprocessing: Benchmon report
# ------------------------------

# software/hardware report file
software_report=()
for f in "$save_dir"/swmon*.json; do
    software_report+=("$f")
done
software_report="${software_report[0]:-}"

hardware_report=()
for f in "$save_dir"/hwmon*.json; do
    hardware_report+=("$f")
done
hardware_report="${hardware_report[0]:-}"

# report template
eval "$($(dirname ${BASH_SOURCE[0]})/benchmon-config)"
report_template="${report_template:-$BENCHMON_LIB_PATH/report/template.md}"

if [[ -f "$report_template" ]]; then
    template_arg=(--template "$report_template")
else
    echo "warning: template not found ($report_template), using default ($BENCHMON_LIB_PATH/report/template.md)" >&2
    template_arg=(--template "$BENCHMON_LIB_PATH/report/template.md")
fi

# figure path for report
figure_path="$traces_repo/benchmon_traces_$(hostname)/benchmon_figure_detailed.png"
if [[ ! -f "$figure_path" ]]; then
    echo "warning: figure not found ($figure_path), report will be generated without image" >&2
fi
figure_arg=(--figure-path "$figure_path")
# optional ps-report
ps_report="$traces_repo/benchmon_traces_$(hostname)/timing_mapping_report.csv"

if [[ -f "$ps_report" ]]; then
    ps_arg=(--ps-report "$ps_report")
else
    echo "warning: timing_mapping_report.csv not found, skipping --ps-report" >&2
    ps_arg=()
fi

# run benchmon report
benchmon-report \
    --software-report "$software_report" \
    --hardware-report "$hardware_report" \
    "${figure_arg[@]}" \
    "${ps_arg[@]}" \
    "${template_arg[@]}" \
    --output "$traces_repo/benchmon_report.md"

# convert to HTML
if command -v pandoc >/dev/null 2>&1 && [[ -f "$traces_repo/benchmon_report.md" ]]; then
    pandoc "$traces_repo/benchmon_report.md" -f markdown -t html \
        -o "$traces_repo/benchmon_report.html"
fi

# ------------------------------
# Postprocessing: HPCtoolkit outputs
# ------------------------------

# Loop on the directories to produce the HPCtoolkit outputs
traces=($save_dir/hpctoolkit_traces/hpctoolkit_*/)
for trace_dir in ${traces[@]}; do
    hpcstruct $trace_dir --cache $(dirname ${trace_dir%/*})cache
    hpcprof -o $(dirname ${trace_dir%/*})/database_$(basename ${trace_dir%/*}) -M stats $trace_dir
done
wait