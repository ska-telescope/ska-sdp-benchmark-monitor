#!/usr/bin/bash

args=""
hpcrun_flags=""
index=0
# Load environment variables exported by the Python benchmon-config script
eval "$($(dirname ${BASH_SOURCE[0]})/benchmon-config)"

# Priority 2: parse command line args
while [[ $# -gt 0 ]]; do
    case $1 in
        "-l" | "--level")
            level=$2
            shift 2
            ;;
        "-d" | "--save-dir")
            save_dir_arg=$2
            shift 2
            ;;
	"-e" | "--hpc-exe")
            while [[ $2 != "-"* && -n $2 ]]; do
                exe[((index++))]=$2
                shift 1
            done
            shift 1
            ;;
	"-f" | "--hpc-flags")
            hpcrun_flags=$2
	    shift 2
	    ;;
        *)
            args="$args $1"
            shift 1
            ;;
    esac
done

# Priority 1: BENCHMON_ARGS overrides level, save-dir, verbose + adds extra args to benchmon-run
if [[ -n "${BENCHMON_ARGS}" ]]; then
    echo "[INFO]: BENCHMON_ARGS is set, overriding matching arguments." >&2
    eval set -- "$BENCHMON_ARGS"
    while [[ $# -gt 0 ]]; do
        case $1 in
            "-l" | "--level")
                level=$2
                shift 2
                ;;
            "-d" | "--save-dir")
                save_dir_arg=$2
                shift 2
                ;;
            "-v" | "--verbose")
                args="$args --verbose"
                shift 1
                ;;
            *)
                args="$args $1"  # extra args (--sys-freq, --call, etc.) passed to benchmon-run
                shift 1
                ;;
        esac
    done
fi

# Priority 3: defaults
level=${level:-0}
save_dir_arg="${save_dir_arg:-./benchmon_savedir_${SLURM_JOB_ID}${OAR_JOB_ID}}"

echo "[INFO]: benchmon-start level=$level save-dir=$save_dir_arg" >&2
args="$args --save-dir $save_dir_arg"

# Create the target directory
mkdir -p "$save_dir_arg"

if [[ $level == 0 ]]; then
    args="--sys --sys-freq 0.2 $args"

elif [[ $level == 1 ]]; then
    # Collect overall performance metrics with hpctoolkit if executables have been passed, otherwise rely on perf
    if [[ ${#exe[@]} != 0 ]]; then
        # Collect overall performance metrics with hpctoolkit, if no hpc-flags have been passed use defaults
        args="--sys --sys-freq 1 $args" # --pow --pow-freq 10
    else
        args="--sys --sys-freq 1 --call --call-prof-freq 1 $args" # --pow --pow-freq 10
    fi

elif [[ $level == 2 ]]; then
    # Collect execution traces with hpctoolkit if executables have been passed, otherwise rely on perf
    if [[ ${#exe[@]} != 0 ]]; then
        # if no hpc-flags have been passed use defaults
        args="--sys --sys-freq 10 $args" # --pow --pow-freq 10
    else
        args="--sys --sys-freq 10 --call --call-prof-freq 50 $args" # --pow --pow-freq 10
    fi
fi

$(dirname ${BASH_SOURCE[0]})/benchmon-run $args &

echo "[INFO]: benchmon-run args: $args" >&2
# In case this file was sourced, unset all local variables
unset args save_dir_arg hpcrun_flags index level exe 
