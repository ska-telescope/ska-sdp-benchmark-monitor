#!/usr/bin/bash
# Sends SIGUSR1 (not SIGTERM) so that benchmon-run is not accidentally stopped
# by SLURM's end-of-job SIGTERM — only an explicit call to benchmon-stop can stop benchmon-run
#   and the user can be sure that when they call benchmon-stop, benchmon-run will be stopped.
benchmon_pid_file=./.benchmon-run_pid_${OAR_JOB_ID}${SLURM_JOB_ID}_$(hostname)
if [[ -f ${benchmon_pid_file} ]]
then
    pid=$(cat ${benchmon_pid_file})
    kill -USR1 ${pid}
    while [ -e /proc/${pid} ]; do
        sleep 0.1;
    done
    rm -v ${benchmon_pid_file}
fi

