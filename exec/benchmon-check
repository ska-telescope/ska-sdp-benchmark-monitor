#!/usr/bin/env python3
import logging
import shutil
import subprocess
import sys
import os
import tempfile
import atexit

logging.basicConfig(level=logging.INFO, format='%(levelname)s: %(message)s')
log = logging.getLogger(__name__)

# Global list to keep track of subprocesses for cleanup
_running_processes = []

# CRITICAL: benchmon cannot produce reliable data without these -> ERROR + abort.
# 'bc' is used by cpu_mon.sh/mem_mon.sh/net_mon.sh/disk_mon.sh
critical_command_check_set = {
    "bc": "bc",
}

# OPTIONAL: missing -> WARNING only, benchmon still works (reduced features).
optional_command_check_set = {
    "perf": "perf",
    "hpcrun": "hpcrun",
    "hpcstruct": "hpcstruct",
    "hpcprof": "hpcprof",
}



command_advice_set = {
    "bc": "The 'bc' command is not available. 'bc' is a basic calculator "
           "utility. To install it, use the following command based on "
           "your Linux distribution:\n"
          "  - For Ubuntu/Debian: `sudo apt-get install bc`\n"
          "  - For CentOS/RHEL: `sudo yum install bc`\n"
          "  - For Fedora: `sudo dnf install bc`",
    "perf": "The 'perf' command is not available. 'perf' is a performance "
             "analysis tool that is part of the Linux kernel tools. "
             "To install it, use the following command based on your "
             "Linux distribution:\n"
            "  - For Ubuntu/Debian: `sudo apt-get install linux-tools-common linux-tools-generic`\n"
            "  - For CentOS/RHEL: `sudo yum install perf`\n"
            "  - For Fedora: `sudo dnf install perf`",
    "hpcrun": "'hpcrun' (hpctoolkit) is not available. hpctoolkit is an "
              "execution trace collection tool with low overhead (without "
              "it, more expensive trace collection is still possible via "
              "perf). Install via Spack: "
              "https://hpctoolkit.org/software-instructions.html",
    "hpcstruct": "'hpcstruct' (hpctoolkit) is not available. See "
                 "https://hpctoolkit.org/software-instructions.html",
    "hpcprof": "'hpcprof' (hpctoolkit) is not available. See "
               "https://hpctoolkit.org/software-instructions.html",
}

sys_monitor_check_set = {
    "cpu": "cat /proc/stat | grep cpu",
    "cpufreq": "cat /sys/devices/system/cpu/cpu0/cpufreq/scaling_cur_freq",
    "mem": "cat /proc/meminfo",
    "net": "cat /proc/net/dev",
    "disk": "cat /proc/diskstats",
    "ib": "cat /sys/class/infiniband/*/ports/1/counters/port*data"
}

# hardware/fabric-dependent -> optional
non_critical_sys_monitor_checks = {"cpufreq", "ib"}

# Temporary file for perf record
_temp_file = tempfile.NamedTemporaryFile(delete=False)
TEMP_PERF_FILE = _temp_file.name
_temp_file.close()

perf_monitor_check_set = {
    "power_event": "perf list | grep -i power/energy | awk '{print $1}'",
    "power_command": "perf stat -A -a -e power/energy-pkg/ -I 100 -x , -- sleep 0.1",
    "call_command": f"perf record --running-time -T -a -F 10 --call-graph dwarf -o {TEMP_PERF_FILE} -- sleep 0.1"
}

perf_monitor_advice_set = {
    "call_command": "The 'perf record' command requires specific kernel settings to collect call "
                   "graph data. To enable this, you need to modify the following kernel parameters:\n"
                    "  - Set `kernel.perf_event_paranoid` to -1\n"
                    "  - Set `kernel.kptr_restrict` to 0\n"
                    "You can do this by running:\n"
                    "  - `sudo sysctl -w kernel.perf_event_paranoid=-1`\n"
                    "  - `sudo sysctl -w kernel.kptr_restrict=0`\n"
                    "To make these changes permanent, add the following lines to `/etc/sysctl.conf`:\n"
                    "  - `kernel.perf_event_paranoid = -1`\n"
                    "  - `kernel.kptr_restrict = 0`\n"
                    "Then, reload the configuration with `sudo sysctl -p`."
}

def cleanup():
    """Clean up temporary files and terminate running processes."""
    if os.path.exists(TEMP_PERF_FILE):
        os.remove(TEMP_PERF_FILE)
    for proc in _running_processes:
        if proc.poll() is None:  # Process is still running
            proc.terminate()
            try:
                proc.wait(timeout=1)
            except subprocess.TimeoutExpired:
                proc.kill()

# Register cleanup function to run at exit
atexit.register(cleanup)

def check_cmd(cmd, advice=None, critical=False):
    """
    Check if the command is valid by running it and checking the return code.
    If the command fails, log the error message from stderr and any provided advice.
    Args:
        cmd (str): The command to check as a shell string.
        advice (str, optional): Advice to log if the command fails.
    Returns:
        bool: True if the command runs successfully (return code 0), False otherwise.
    """
    try:
        result = subprocess.run(cmd, shell=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)
        if result.returncode != 0:
            if critical:
                log.error(f"Command '{cmd}' failed with return code {result.returncode}: {result.stderr.strip()}")
            else:
                log.warning(f"Command '{cmd}' failed with return code {result.returncode}: {result.stderr.strip()}")
            if advice:
                log.info(f"Advice: {advice}")
            return False
        return True
    except Exception as e:
        if critical:
            log.error(f"Exception while running command '{cmd}': {e}")
        else:
            log.warning(f"Exception while running command '{cmd}': {e}")
        if advice:
            log.info(f"Advice: {advice}")
        return False


def check_binary_available(cmd, advice, critical=False):
    """
    Check if the binary is available in the system PATH.
    If not, log the advice.
    Args:
        cmd (str): The command/binary name to check.
        advice (str): Advice to log if the binary is not found.
    Returns:
        bool: True if the binary is found, False otherwise.
    """
    if shutil.which(cmd) is None:
        if critical:
            log.error(f"Critical command '{cmd}' is not available.")
        else:
            log.warning(f"Base command '{cmd}' is not available.")
        log.info(f"Advice: {advice}")
        return False
    return True

def check_benchmon_env():
    """
    Check if the benchmark environment is ready.
    Runs ALL checks (never stops at the first failure) so every problem is
    reported together in a single run. Returns False only if at least one
    CRITICAL requirement is missing; non-critical issues are warnings only.
    """
    critical_failures = []
    warning_count = 0

    # --- Critical base commands (bc) ---
    for name, cmd in critical_command_check_set.items():
        if not check_binary_available(cmd, command_advice_set.get(name), critical=True):
            critical_failures.append(name)

    # --- Optional base commands (perf, hpctoolkit binaries) ---
    for name, cmd in optional_command_check_set.items():
        if not check_binary_available(cmd, command_advice_set.get(name), critical=False):
            warning_count += 1

    # --- Essential /proc files: without these, sys monitoring cannot work at all ---
    essential_files = ["/proc/stat", "/proc/meminfo", "/proc/net/dev", "/proc/diskstats"]
    for file in essential_files:
        if not os.path.exists(file):
            log.error(f"Critical file '{file}' does not exist.")
            log.info("Advice: Ensure that the system is properly configured and the necessary kernel modules are loaded.")
            critical_failures.append(file)

    # --- Optional /sys files (cpufreq: hardware-dependent, safe to continue) ---
    optional_files = [
        "/sys/devices/system/cpu/cpu0/cpufreq/scaling_cur_freq",
        "/sys/devices/system/cpu/cpu0/cpufreq/cpuinfo_min_freq",
        "/sys/devices/system/cpu/cpu0/cpufreq/cpuinfo_max_freq",
    ]
    for file in optional_files:
        if not os.path.exists(file):
            log.warning(f"Optional file '{file}' does not exist, but continuing.")
            warning_count += 1

    # --- Monitoring commands: cpu/mem/net/disk critical, cpufreq/ib optional ---
    for name, cmd in sys_monitor_check_set.items():
        critical = name not in non_critical_sys_monitor_checks
        if not check_cmd(cmd, critical=critical):
            if critical:
                critical_failures.append(name)
            else:
                log.info(f"Command '{name}' failed to run: {cmd}, but continuing.")
                warning_count += 1

    # --- perf-based checks: all optional (power/call profiling are opt-in) ---
    for name, cmd in perf_monitor_check_set.items():
        advice = perf_monitor_advice_set.get(name)
        if not check_cmd(cmd, advice, critical=False):
            log.info(f"Command '{name}' failed to run: {cmd}, but continuing.")
            warning_count += 1

    if critical_failures:
        log.error(
            f"Critical requirement(s) missing/failed: {', '.join(critical_failures)}. "
            f"benchmon cannot produce reliable monitoring data without them."
        )
        return False

    if warning_count:
        log.info(f"{warning_count} non-critical warning(s) reported above; continuing.")
    return True

def main():
    """
    Main function to check the benchmark environment and log the result.
    Exits with status 1 if a critical requirement is missing, so calling
    scripts (e.g. benchmon-setup) can detect failure and abort instead of
    silently continuing with broken/incomplete monitoring.
    """
    if check_benchmon_env():
        log.info("Benchmark environment is ready.")
        sys.exit(0)
    else:
        log.error("Benchmark environment is NOT ready (see critical errors above). Aborting.")
        sys.exit(1)

if __name__ == "__main__":
    main()
